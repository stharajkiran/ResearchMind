# LLM providers
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Data sources
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_API_KEY=

# AWS (arXiv S3 bulk access)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Redis
REDIS_URL=redis://localhost:6379

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/researchmind

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# LangSmith
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=researchmind

# Qdrant (optional — only needed when swapping from FAISS+Chroma to Qdrant)
QDRANT_URL=http://localhost:6333

# Config selection — loads configs/{CONFIG_NAME}.yaml
# Options: phase2 | semantic | demo  (or any custom config you add to configs/)
# demo = 233-paper corpus + Haiku LLM tiers (no Ollama needed)
CONFIG_NAME=phase2
